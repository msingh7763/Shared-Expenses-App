# ── Database ──────────────────────────────────────────────────────────────────
# Render provides this automatically when you attach a PostgreSQL instance
DATABASE_URL="postgresql://user:password@host:5432/spreetail_db"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Vercel deployment URL (no trailing slash)
# e.g.  https://spreetail.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Currency ──────────────────────────────────────────────────────────────────
USD_TO_INR_RATE=84.5
